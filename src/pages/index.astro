---
const profile = {
  name: 'Jeewon Jeon',
  tagline: '한 줄 소개를 여기에 적어주세요.',
};

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/posts', label: 'Posts' },
];

const sectionLinks = [
  { href: '/about', label: 'About', description: '나를 소개하는 공간' },
  { href: '/projects', label: 'Projects', description: '작업을 모으는 공간' },
  { href: '/posts', label: 'Posts', description: '기록을 남기는 공간' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{profile.name} | Personal Homepage</title>
    <meta
      name="description"
      content={`${profile.name}의 개인 홈페이지입니다.`}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">{profile.name}</a>
      <nav aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={item.href === '/' ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main>
      <section class="hero">
        <h1>{profile.name}</h1>
        <p class="tagline">{profile.tagline}</p>
        <p class="summary">
          저를 소개하고, 만든 것들을 정리하고, 생각을 기록하는 개인 홈페이지입니다.
        </p>
      </section>

      <section class="sections" aria-label="Future sections">
        {
          sectionLinks.map((section) => (
            <a class="section-button" href={section.href}>
              <span>{section.label}</span>
              <strong>{section.description}</strong>
            </a>
          ))
        }
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color: #15171a;
    background: #ffffff;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    margin: 0;
    background: #ffffff;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100% - 3rem, 1040px);
    margin: 0 auto;
    padding: 2.25rem 0;
  }

  .brand {
    font-size: 0.95rem;
    font-weight: 700;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: flex-end;
  }

  nav a {
    color: #5b636d;
    font-size: 0.9rem;
  }

  nav a[aria-current='page'] {
    color: #15171a;
    font-weight: 700;
  }

  main {
    width: min(100% - 3rem, 1040px);
    margin: 0 auto;
    padding: 8rem 0 5rem;
  }

  .hero {
    max-width: 840px;
  }

  h1 {
    margin: 0;
    font-size: clamp(4.5rem, 13vw, 10rem);
    line-height: 0.95;
  }

  .tagline {
    max-width: 680px;
    margin: 2rem 0 0;
    color: #15171a;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 600;
    line-height: 1.4;
  }

  .summary {
    max-width: 620px;
    margin: 1rem 0 0;
    color: #5b636d;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .sections {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 7rem;
    padding-top: 2rem;
    border-top: 1px solid #eceef0;
  }

  .section-button {
    display: flex;
    min-height: 120px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid #dfe3e8;
    border-radius: 18px;
    padding: 1.25rem;
    background: #ffffff;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .section-button:hover {
    transform: translateY(-2px);
  }

  .section-button span {
    color: #6f7782;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .section-button strong {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 800;
    line-height: 1.35;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding-top: 5rem;
    }

    h1 {
      font-size: 4.25rem;
    }

    .tagline {
      font-size: 1.45rem;
    }

    .summary {
      font-size: 1.05rem;
    }

    .sections {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-top: 5rem;
    }
  }
</style>
